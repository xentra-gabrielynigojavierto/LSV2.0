{
  "name": "@legalsynq/notifications-service",
  "version": "0.1.0",
  "description": "LegalSynq notifications foundation service",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "worker:notifications": "ts-node-dev --respawn --transpile-only src/workers/notification.worker.ts",
    "worker:provider-health": "ts-node-dev --respawn --transpile-only src/workers/provider-health.worker.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.5",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^7.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "lodash": "4.18.0",
    "uuid": "^11.0.5"
  }
}
