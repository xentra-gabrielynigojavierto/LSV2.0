{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Monitoring": {
    "Scheduler": {
      "Enabled": true,
      "IntervalSeconds": 15
    },
    "HttpCheck": {
      "TimeoutSeconds": 5
    },
    "UptimeAggregation": {
      "Enabled": true,
      "IntervalSeconds": 60,
      "LookbackDays": 91
    }
  },
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "dev-only-signing-key-minimum-32-chars-long!"
  },
  "ServiceTokens": {
    "SigningKey": "dev-flow-service-token-signing-key-32chars!",
    "ServiceName": "monitoring-service"
  },
  "MonitoringBootstrap": {
    "Enabled": true
  }
}
