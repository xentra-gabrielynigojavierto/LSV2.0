{
  "Urls": "http://0.0.0.0:5015",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "monitoring"
  },
  "Monitoring": {
    "Scheduler": {
      "Enabled": true,
      "IntervalSeconds": 60
    },
    "HttpCheck": {
      "TimeoutSeconds": 10,
      "AllowInternalTargets": true
    },
    "UptimeAggregation": {
      "Enabled": true,
      "IntervalSeconds": 300,
      "LookbackDays": 91
    }
  },
  "ConnectionStrings": {
    "MonitoringDb": "Server=localhost;Port=3306;Database=monitoring;User=monitoring;Password=monitoring;"
  },
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "REPLACE_VIA_SECRET_minimum_32_characters_long"
  },
  "MonitoringBootstrap": {
    "Enabled": false
  }
}
