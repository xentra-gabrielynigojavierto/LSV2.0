{
  "Authentication": {
    "Jwt": {
      "Issuer": "legalsynq-identity",
      "Audience": "legalsynq-platform",
      "SymmetricKey": "dev-only-signing-key-minimum-32-chars-long!",
      "RequireHttpsMetadata": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AuditClient": {
    "BaseUrl": "http://localhost:5007",
    "ServiceToken": "",
    "SourceSystem": "support-service",
    "SourceService": "support-api",
    "TimeoutSeconds": 5
  },
  "ServiceTokens": {
    "Issuer": "legalsynq-service-tokens",
    "Audience": "flow-service",
    "LifetimeMinutes": 5,
    "ServiceName": "support-service"
  },
  "Support": {
    "Notifications": {
      "Enabled": true,
      "Mode": "Http",
      "BaseUrl": "http://localhost:5008",
      "PortalBaseUrl": "http://localhost:3050",
      "TimeoutSeconds": 5
    },
    "Audit": {
      "Enabled": true,
      "Mode": "Http",
      "TimeoutSeconds": 5
    },
    "FileStorage": {
      "Mode": "Local",
      "LocalRootPath": "./data/support-uploads"
    }
  }
}
