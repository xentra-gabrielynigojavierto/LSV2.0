{
  "Jwt": {
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform",
    "SigningKey": "dev-only-signing-key-minimum-32-chars-long!",
    "ExpiryMinutes": "480"
  },
  "TenantVerification": {
    "DevBypass": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "NotificationsService": {
    "BaseUrl": "",
    "InternalServiceToken": "",
    "TimeoutSeconds": 10,
    // Development: PortalBaseDomain is intentionally empty. PortalBaseUrl (localhost) is used
    // as the fallback so invite/reset links work locally without DNS subdomain setup.
    // In staging/production, set NotificationsService__PortalBaseDomain instead
    // (e.g. "portal.legalsynq.com"). Startup validation is skipped in Development.
    "PortalBaseUrl": "http://localhost:3050",
    "PortalBaseDomain": ""
  }
}
