{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5006"
      }
    }
  },
  "ConnectionStrings": {
    "DocsDb": "server=legalsynqplatform.cpq48wc2krn5.us-east-2.rds.amazonaws.com;port=3306;database=documents_db;user=admin;password=REPLACE_VIA_SECRET"
  },
  "Jwt": {
    "SigningKey": "REPLACE_VIA_SECRET_minimum_32_characters_long",
    "JwksUri": "",
    "Issuer": "legalsynq-identity",
    "Audience": "legalsynq-platform"
  },
  "Storage": {
    "Provider": "s3",
    "Local": {
      "BasePath": "/home/runner/data/docs-local"
    },
    "S3": {
      "BucketName": "docs-prod",
      "Region": "us-east-1"
    }
  },
  "Scanner": {
    "Provider": "mock",
    "ClamAv": {
      "Host": "localhost",
      "Port": 3310,
      "TimeoutMs": 30000,
      "ChunkSizeBytes": 2097152,
      "SignatureMaxAgeHours": 24,
      "MaxScannableFileSizeMb": 25,
      "CircuitBreaker": {
        "FailureThreshold": 5,
        "BreakDurationSeconds": 30,
        "SamplingDurationSeconds": 60,
        "MinimumThroughput": 5
      }
    },
    "Mock": {
      "MockResult": "clean"
    }
  },
  "ScanWorker": {
    "QueueProvider": "memory",
    "QueueCapacity": 1000,
    "WorkerCount": 2,
    "MaxRetryAttempts": 3,
    "InitialRetryDelaySeconds": 5,
    "MaxRetryDelaySeconds": 120,
    "ClaimStaleJobsAfterSeconds": 300,
    "StreamKey": "docs:scan:jobs",
    "ConsumerGroup": "scan-workers",
    "StreamMaxLength": 50000
  },
  "Redis": {
    "Url": "",
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "BreakDurationSeconds": 30,
      "SamplingDurationSeconds": 60,
      "MinimumThroughput": 5
    }
  },
  "AccessToken": {
    "Store": "memory",
    "TtlSeconds": 300,
    "RedirectTtlSeconds": 30,
    "OneTimeUse": true
  },
  "Documents": {
    "RequireCleanScanForAccess": true,
    "SignedUrlTtlSeconds": 300,
    "MaxUploadSizeMb": 25,
    "MaxScannableFileSizeMb": 25
  },
  "Notifications": {
    "ScanCompletion": {
      "Provider": "log",
      "Redis": {
        "Channel": "documents.scan.completed",
        "StreamKey": "documents:scan:completed",
        "StreamMaxLength": 100000
      }
    }
  },
  "Cors": {
    "Origins": "*"
  },
  "AllowedHosts": "*"
}
