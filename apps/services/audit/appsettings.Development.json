{
  "AuditService": {
    "ExposeSwagger": true,
    "AllowedCorsOrigins": [ "*" ]
  },

  "Database": {
    "Provider": "MySQL",
    "EnableDetailedErrors": true,
    "VerifyConnectionOnStartup": true,
    "MigrateOnStartup": true
  },

  "_jwt_comment": "Symmetric signing key matches the dev key in Identity.Api/appsettings.Development.json and Gateway.Api/appsettings.Development.json. All three must stay in sync. In production, inject Jwt__SigningKey via environment variable — never commit a real key.",
  "Jwt": {
    "SigningKey": "dev-only-signing-key-minimum-32-chars-long!",
    "Audience": "platform-audit-api",
    "RequireHttpsMetadata": false,
    "ValidateAudience": false,
    "ValidateIssuer": false,
    "ValidateLifetime": true,
    "RequireConfigurationInBearerMode": true
  },

  "_integrity_comment": "HmacKeyBase64 must be set via the Integrity__HmacKeyBase64 environment variable (or user-secrets) in any environment where VerifyOnRead is true. Never hardcode a real key here.",
  "Integrity": {
    "Algorithm": "HMAC-SHA256",
    "HmacKeyBase64": "",
    "VerifyOnRead": false
  },

  "IngestAuth": {
    "Mode": "None",
    "ServiceTokens": [
      {
        "Token": "dev-service-token-identity-REPLACE-IN-PROD",
        "ServiceName": "identity-service",
        "Description": "Identity microservice — dev token only",
        "Enabled": true
      },
      {
        "Token": "dev-service-token-fund-REPLACE-IN-PROD",
        "ServiceName": "fund-service",
        "Description": "Fund microservice — dev token only",
        "Enabled": true
      },
      {
        "Token": "dev-service-token-careconnect-REPLACE-IN-PROD",
        "ServiceName": "care-connect-api",
        "Description": "CareConnect API — dev token only",
        "Enabled": true
      }
    ],
    "RequireSourceSystemHeader": false,
    "AllowedSources": []
  },

  "QueryAuth": {
    "Mode": "Bearer",
    "EnforceTenantScope": false,
    "ExposeIntegrityHash": true,

    "PlatformAdminRoles": [ "PlatformAdmin", "platform-audit-admin" ],
    "TenantAdminRoles":   [ "TenantAdmin", "tenant-admin", "compliance-officer" ],
    "TenantUserRoles":    [ "StandardUser", "tenant-user", "user" ],

    "TenantIdClaimType":       "tenant_id",
    "OrganizationIdClaimType": "org_id",
    "UserIdClaimType":         "sub",
    "RoleClaimType":           "role"
  },

  "Export": {
    "Provider": "Local",
    "LocalOutputPath": "exports",
    "MaxRecordsPerFile": 10000,
    "SupportedFormats": [ "Json", "Csv", "Ndjson" ],
    "FileNamePrefix": "audit-export"
  },

  "Retention": {
    "JobEnabled": false,
    "DryRun": true,
    "DefaultRetentionDays": 0,
    "HotRetentionDays": 365,
    "ArchiveBeforeDelete": false,
    "LegalHoldEnabled": false
  },

  "Archival": {
    "Strategy": "NoOp",
    "LocalOutputPath": "archive"
  },

  "EventForwarding": {
    "Enabled": false,
    "BrokerType": "NoOp",
    "MinSeverity": "Info",
    "ForwardReplayRecords": false,
    "ForwardCategories": [],
    "ForwardEventTypePrefixes": []
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "Microsoft": "Information",
        "System": "Information"
      }
    }
  }
}
