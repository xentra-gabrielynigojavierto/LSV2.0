{
  "_comment": [
    "Production overrides for Platform Audit/Event Service.",
    "This file commits hardened baseline defaults.",
    "Secrets and per-deployment values MUST be injected via environment variables.",
    "Never commit tokens, passwords, or connection strings here.",
    "",
    "Environment variable naming convention (ASP.NET Core double-underscore):",
    "  IngestAuth__Mode = ServiceToken",
    "  IngestAuth__ServiceTokens__0__Token = <value>",
    "  IngestAuth__ServiceTokens__0__ServiceName = identity-service",
    "  IngestAuth__ServiceTokens__0__Enabled = true",
    "  QueryAuth__Mode = Bearer",
    "  Database__Provider = MySQL",
    "  Database__ConnectionString = <value>",
    "  Integrity__HmacKeyBase64 = <value>",
    "  ConnectionStrings__AuditEventDb = <value>  (alternative to Database__ConnectionString)"
  ],

  "ServicePort": "5007",

  "AuditService": {
    "ExposeSwagger": false,
    "AllowedCorsOrigins": []
  },

  "Database": {
    "Provider": "MySQL",
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "VerifyConnectionOnStartup": true,
    "MigrateOnStartup": true
  },

  "Integrity": {
    "Algorithm": "HMAC-SHA256",
    "VerifyOnRead": true,
    "FlagTamperedRecords": true
  },

  "IngestAuth": {
    "Mode": "None",
    "RequireSourceSystemHeader": false
  },

  "_ingestauth_comment": "Set Mode to ServiceToken and configure tokens when service-to-service auth is ready.",
  "_queryauth_comment": "Mode=Bearer — JWT must be validated. PlatformAdminRoles must include the role emitted by Identity.Api (currently 'PlatformAdmin').",
  "QueryAuth": {
    "Mode": "Bearer",
    "EnforceTenantScope": true,
    "ExposeIntegrityHash": false,
    "PlatformAdminRoles": [ "PlatformAdmin", "platform-audit-admin" ],
    "TenantAdminRoles":   [ "TenantAdmin", "tenant-admin", "compliance-officer" ],
    "TenantUserRoles":    [ "StandardUser", "tenant-user", "user" ]
  },

  "_jwt_comment": "SigningKey must be injected via the Jwt__SigningKey environment variable in production. It must match the key used by Identity.Api to sign platform JWTs. Authority is unused when SigningKey is present. The fallback value below matches the placeholder used by Identity.Api and Gateway.Api — override it via Jwt__SigningKey env var with the real production key.",
  "Jwt": {
    "SigningKey": "REPLACE_VIA_SECRET_minimum_32_characters_long",
    "Audience": "platform-audit-api",
    "RequireHttpsMetadata": false,
    "ValidateAudience": false,
    "ValidateIssuer": false,
    "ValidateLifetime": true,
    "RequireConfigurationInBearerMode": true
  },

  "Outbox": {
    "Enabled": false
  },

  "EventForwarding": {
    "Enabled": false
  },

  "Retention": {
    "DryRun": false,
    "LegalHoldEnabled": true
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-ddTHH:mm:ssZ} {Level:u3}] [{CorrelationId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*"
}
