{
  "AuditService": {
    "ServiceName": "Platform Audit/Event Service",
    "Version": "1.0.0",
    "EnvironmentTag": null,
    "ExposeSwagger": false,
    "AllowedCorsOrigins": []
  },

  "Database": {
    "Provider": "MySQL",
    "ConnectionString": null,
    "ServerVersion": "8.0.0-mysql",
    "MaxPoolSize": 100,
    "MinPoolSize": 5,
    "ConnectionTimeoutSeconds": 30,
    "CommandTimeoutSeconds": 60,
    "MigrateOnStartup": false,
    "VerifyConnectionOnStartup": true,
    "StartupProbeTimeoutSeconds": 10,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },

  "Integrity": {
    "HmacKeyBase64": "",
    "Algorithm": "HMAC-SHA256",
    "VerifyOnRead": false,
    "FlagTamperedRecords": true
  },

  "IngestAuth": {
    "Mode": "None",
    "ServiceTokens": [],
    "RequireSourceSystemHeader": false,
    "AllowedSources": [],
    "ApiKey": null,
    "ApiKeyHeader": "X-Api-Key",
    "RequiredClaims": [],
    "RequiredRole": null
  },

  "QueryAuth": {
    "Mode": "None",

    "PlatformAdminRoles":    [ "PlatformAdmin", "platform-audit-admin" ],
    "TenantAdminRoles":      [ "TenantAdmin", "tenant-admin", "compliance-officer" ],
    "OrganizationAdminRoles":[ "org-admin", "department-admin" ],
    "RestrictedRoles":       [ "compliance-reader", "auditor" ],
    "TenantUserRoles":       [ "StandardUser", "tenant-user", "user" ],
    "UserSelfRoles":         [ "self-reader" ],

    "TenantIdClaimType":       "tenant_id",
    "OrganizationIdClaimType": "org_id",
    "UserIdClaimType":         "sub",
    "RoleClaimType":           "role",

    "EnforceTenantScope":  true,
    "MaxPageSize":         500,
    "ExposeIntegrityHash": false
  },

  "Retention": {
    "DefaultRetentionDays": 0,
    "CategoryOverrides": {},
    "TenantOverrides": {},
    "JobEnabled": false,
    "JobCronUtc": "0 2 * * *",
    "MaxDeletesPerRun": 10000,
    "ArchiveBeforeDelete": false,
    "HotRetentionDays": 365,
    "DryRun": true,
    "LegalHoldEnabled": false
  },

  "Archival": {
    "Strategy": "NoOp",
    "BatchSize": 10000,
    "LocalOutputPath": "archive",
    "FileNamePrefix": "audit-archive",
    "S3BucketName": null,
    "S3KeyPrefix": null,
    "AwsRegion": null,
    "AzureBlobConnectionString": null,
    "AzureContainerName": null
  },

  "EventForwarding": {
    "Enabled": false,
    "BrokerType": "NoOp",
    "ConnectionString": null,
    "TopicOrExchangeName": null,
    "SubjectPrefix": "legalsynq.audit.",
    "ForwardCategories": [],
    "ForwardEventTypePrefixes": [],
    "MinSeverity": "Info",
    "ForwardReplayRecords": false
  },

  "Export": {
    "Provider": "None",
    "SupportedFormats": [ "Json", "Csv", "Ndjson" ],
    "MaxRecordsPerFile": 100000,
    "LocalOutputPath": null,
    "S3BucketName": null,
    "S3KeyPrefix": null,
    "AwsRegion": null,
    "AzureBlobConnectionString": null,
    "AzureContainerName": null,
    "FileNamePrefix": "audit-export"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*"
}
