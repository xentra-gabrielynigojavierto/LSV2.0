# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — Control Center
#
# Files and directories excluded from the Docker build context.
# Keeping the context small:
#   a) speeds up docker build (less data sent to the daemon)
#   b) prevents secrets from accidentally entering the image
#   c) prevents stale build artefacts from being copied into the builder stage
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies (reinstalled inside the image) ───────────────────────────────
node_modules
.pnp
.pnp.js

# ── Build cache (regenerated by next build) ───────────────────────────────────
.next/cache

# ── Environment files (secrets must never enter the image) ───────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*

# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Editor and tooling ────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── TypeScript source maps (not needed at runtime) ───────────────────────────
*.map

# ── Test infrastructure ───────────────────────────────────────────────────────
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
jest.config.*
vitest.config.*
playwright.config.*

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
CHANGELOG.md
